{
  "name": "typescript-pnpm-docker-boilerplate",
  "version": "1.0.0",
  "description": "A TypeScript boilerplate with pnpm, Docker, and DevContainers support",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "start": "pnpm dev",
    "start:dev": "vite",
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "validate": "make validate",
    "prepare": "husky",
    "clean": "rm -rf dist node_modules .pnpm-store",
    "clean:install": "pnpm clean && pnpm install"
  },
  "dependencies": {
    "vite": "^8.1.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "esbuild": "0.28.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.5"
  }
}
