FROM node:26-alpine

# Install system dependencies (make: runs the project's Makefile, e.g. `make validate`)
RUN apk add --no-cache git bash wget curl make

# Create pnpm store directory with proper permissions before switching users
RUN mkdir -p /home/node/.pnpm-store && chown -R node:node /home/node/.pnpm-store

# Copy scripts and make them executable
COPY scripts/ /app/scripts/
RUN chmod +x /app/scripts/*.sh

# Install pnpm globally as root (before switching users) via npm rather than
# corepack or the get.pnpm.io standalone installer: both of those resolve the
# pinned version through the native @pnpm/exe package, which only ships
# glibc-linked binaries and silently breaks on this Alpine (musl) image.
RUN npm install -g pnpm@9.0.0

# Switch to node user early
USER node
WORKDIR /home/node

# Set the working directory
WORKDIR /app

# Keep container running
CMD ["sleep", "infinity"]
